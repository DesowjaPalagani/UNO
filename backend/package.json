    "@types/socket.io": "^3.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^5.48.0",
    "@typescript-eslint/parser": "^5.48.0",
    "eslint": "^8.31.0",
    "jest": "^29.0.0",
    "prisma": "^4.11.0",
    "ts-jest": "^29.0.3",
    "ts-node": "^10.9.1",
