# Development Environment
NODE_ENV=development

# Server
PORT=5000
HOST=localhost

# Database (MongoDB - Local or Atlas)
# Option 1 - Local MongoDB:
# DATABASE_URL="mongodb://localhost:27017/uno_game"
# Option 2 - MongoDB Atlas (Recommended):
DATABASE_URL="mongodb+srv://uno_user:password@uno-game-cluster.xxxxx.mongodb.net/uno_game?retryWrites=true&w=majority"

# JWT
JWT_SECRET="dev-secret-key-min-32-chars-long-change-in-production"
JWT_EXPIRATION="24h"
SESSION_SECRET="dev-session-key-min-32-chars-long-change-in-production"

# Frontend URL (CORS)
FRONTEND_URL="http://localhost:3000"
CORS_ORIGIN="http://localhost:3000"

# API Configuration
API_BASE_URL="http://localhost:5000"
API_PREFIX="/api"

# Socket.io
SOCKET_NAMESPACE="/socket.io"
SOCKET_ORIGINS="http://localhost:3000"

# Logging
LOG_LEVEL="debug"

# Game Settings
MIN_PLAYERS=2
MAX_PLAYERS=10
INITIAL_HAND_SIZE=7

# Security
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
